# Copie ce fichier vers .env.stack (fichier ignoré par git) puis complète les variables.
#   cp .env.stack.example .env.stack
#
# SÉCURITÉ : ne jamais committer .env.stack ni y mettre de vrais secrets pour un dépôt public.
# Définis les mots de passe uniquement dans .env.stack en local (gestionnaire de mots de passe,
# secrets Docker / CI). Les lignes ci-dessous ne contiennent pas de secrets d’exemple.
#
# Variables sensibles à ajouter dans ton .env.stack (non versionné) si tu veux surcharger
# les valeurs par défaut du fichier docker-compose.stack.yml (défauts réservés au dev local) :
#   COBOL_EMUL_VSCODE_PASSWORD=…
#   COBOL_EMUL_DB2_PASSWORD=…
#
# Utilisation :
#   docker compose -f docker-compose.yml -f docker-compose.stack.yml --env-file .env.stack --profile ide up -d code-server
#   docker compose -f docker-compose.yml -f docker-compose.stack.yml --env-file .env.stack --profile db2 up -d db2

# --- IDE web (code-server) ---
COBOL_EMUL_CODE_PORT=8443

# --- Hercules (TN3270 -> conteneur) ---
COBOL_EMUL_TN3270=3270

# --- IBM Db2 Community ---
COBOL_EMUL_DB2_TAG=latest
COBOL_EMUL_DB2_PORT=50000
